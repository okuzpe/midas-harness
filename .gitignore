# Secrets — never commit
.env
.env.*
!.env.example
*.pem
*.key
*secret*
*credential*
.claude/settings.local.json

# Node
node_modules/
npm-debug.log*

# Midas volatile state (the durable state.yaml IS committed; caches/hashes are not)
.harness/cache/
.harness/*.hash
**/.DS_Store
Thumbs.db

