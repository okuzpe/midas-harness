{
  "name": "taskpilot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check src",
    "format": "biome format --write src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "next": "15.3.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "drizzle-orm": "0.40.1",
    "@neondatabase/serverless": "0.10.4",
    "bcrypt": "5.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@commitlint/cli": "19.6.1",
    "@commitlint/config-conventional": "19.6.0",
    "@types/bcrypt": "5.0.2",
    "drizzle-kit": "0.30.1",
    "lefthook": "1.10.1",
    "typescript": "5.7.3",
    "vitest": "2.1.8"
  }
}
