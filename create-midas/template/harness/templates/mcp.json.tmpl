{
  "{{!": "TEMPLATE — rendered by /midas-init into project-root .mcp.json. Placeholders use ${ENV_VAR} syntax (shell-style, secret-free). Never commit real credentials. Re-render with /midas-doctor.",

  "mcpServers": {

    "{{!recommended-context7}}": "RECOMMENDED (optional) — fetch current library docs before third-party code (harness/rules/context7-usage.md). Uncomment to wire Context7, or use your own doc tool / web fetch. Add CONTEXT7_API_KEY in your env to raise the free-tier rate limit.",
    "{{!context7}}": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp",
      "headers": { "Authorization": "Bearer ${CONTEXT7_API_KEY}" }
    },

    "sequential-thinking": {
      "{{!comment}}": "ESSENTIAL — structured multi-step reasoning for architecture and audit phases.",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
    },

    "{{!recommended-git}}": "RECOMMENDED — uncomment to enable git MCP (read-only by default; least-privilege).",
    "{{!git}}": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-git", "--repository", "."],
      "env": {}
    },

    "{{!recommended-github}}": "RECOMMENDED — uncomment to enable GitHub MCP (requires PAT with minimal scopes).",
    "{{!github}}": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    },

    "{{!recommended-fetch}}": "RECOMMENDED — uncomment to enable HTTP fetch MCP for web fallback when Context7 is unavailable.",
    "{{!fetch}}": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-fetch"]
    },

    "{{!recommended-filesystem}}": "RECOMMENDED — uncomment to enable filesystem MCP. Scope to project root; never grant write to home dir.",
    "{{!filesystem}}": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "."],
      "env": {}
    },

    "{{!optional-playwright}}": "OPTIONAL — browser automation to DRIVE the UI (E2E flows: navigate/click/fill/assert + screenshots; cross-browser). Used by /midas-verify rung 4. Load only for UI verification.",
    "{{!playwright}}": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"]
    },

    "{{!optional-chrome-devtools}}": "OPTIONAL — Chrome DevTools to INSPECT runtime health (console errors, failed network requests, performance/Core Web Vitals, Lighthouse). Complements Playwright in /midas-verify. ~17k tokens on load; needs Chrome + Node >=20.19/22.12. Load only for UI verification.",
    "{{!chrome-devtools}}": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest"]
    }

  }
}
