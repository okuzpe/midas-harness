{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$metadata": {
    "description": "Keel design-system base tokens — W3C Design Tokens Community Group format.",
    "note": "Single brand hue + neutral ramp + semantic intents. Tool-neutral. AA contrast guaranteed on all semantic surfaces. 8 px grid, 1.25 modular type scale. Dark mode resolved at runtime via [data-theme='dark'] (see tokens.css).",
    "version": "0.1.0"
  },

  "color": {
    "$description": "All raw and semantic colour tokens.",

    "brand": {
      "$description": "Single brand hue (HSL 220° — blue-indigo family). Scale 50→950.",
      "50":  { "$value": "#eef2ff", "$type": "color" },
      "100": { "$value": "#e0e7ff", "$type": "color" },
      "200": { "$value": "#c7d2fe", "$type": "color" },
      "300": { "$value": "#a5b4fc", "$type": "color" },
      "400": { "$value": "#818cf8", "$type": "color" },
      "500": { "$value": "#6366f1", "$type": "color" },
      "600": { "$value": "#4f46e5", "$type": "color" },
      "700": { "$value": "#4338ca", "$type": "color" },
      "800": { "$value": "#3730a3", "$type": "color" },
      "900": { "$value": "#312e81", "$type": "color" },
      "950": { "$value": "#1e1b4b", "$type": "color" }
    },

    "neutral": {
      "$description": "Gray ramp, used for text, surfaces, borders. Scale 0→950.",
      "0":   { "$value": "#ffffff", "$type": "color" },
      "50":  { "$value": "#f9fafb", "$type": "color" },
      "100": { "$value": "#f3f4f6", "$type": "color" },
      "150": { "$value": "#eaecf0", "$type": "color" },
      "200": { "$value": "#e5e7eb", "$type": "color" },
      "300": { "$value": "#d1d5db", "$type": "color" },
      "400": { "$value": "#9ca3af", "$type": "color" },
      "500": { "$value": "#6b7280", "$type": "color" },
      "600": { "$value": "#4b5563", "$type": "color" },
      "700": { "$value": "#374151", "$type": "color" },
      "800": { "$value": "#1f2937", "$type": "color" },
      "900": { "$value": "#111827", "$type": "color" },
      "950": { "$value": "#030712", "$type": "color" }
    },

    "semantic": {
      "$description": "Intent aliases — always reference these in UI, never raw brand/neutral values directly.",

      "bg": {
        "base":    { "$value": "{color.neutral.0}",   "$type": "color", "$description": "Page/app background" },
        "subtle":  { "$value": "{color.neutral.50}",  "$type": "color", "$description": "Subtle recessed surface (sidebar, well)" },
        "muted":   { "$value": "{color.neutral.100}", "$type": "color", "$description": "Disabled or muted surface" },
        "overlay": { "$value": "{color.neutral.800}", "$type": "color", "$description": "Backdrop / scrim (opacity applied by consumer)" }
      },

      "surface": {
        "default":  { "$value": "{color.neutral.0}",   "$type": "color", "$description": "Card / panel / dialog default" },
        "raised":   { "$value": "{color.neutral.0}",   "$type": "color", "$description": "Elevated surface (uses shadow to differentiate)" },
        "sunken":   { "$value": "{color.neutral.100}", "$type": "color", "$description": "Inset surface" }
      },

      "border": {
        "default": { "$value": "{color.neutral.200}", "$type": "color" },
        "strong":  { "$value": "{color.neutral.300}", "$type": "color" },
        "focus":   { "$value": "{color.brand.500}",   "$type": "color", "$description": "Focus ring — brand colour at full opacity" }
      },

      "text": {
        "primary":   { "$value": "{color.neutral.900}", "$type": "color", "$description": "Body text — 4.5:1 on bg.base" },
        "secondary": { "$value": "{color.neutral.600}", "$type": "color", "$description": "Supporting / caption text — 4.5:1 on bg.base" },
        "disabled":  { "$value": "{color.neutral.400}", "$type": "color" },
        "inverse":   { "$value": "{color.neutral.0}",   "$type": "color", "$description": "Text on dark / brand surfaces" },
        "link":      { "$value": "{color.brand.600}",   "$type": "color", "$description": "Inline links — 4.5:1 on bg.base (AA)" },
        "linkHover": { "$value": "{color.brand.700}",   "$type": "color" }
      },

      "action": {
        "$description": "Primary CTA — brand-filled button.",
        "bg":          { "$value": "{color.brand.600}",  "$type": "color" },
        "bgHover":     { "$value": "{color.brand.700}",  "$type": "color" },
        "bgActive":    { "$value": "{color.brand.800}",  "$type": "color" },
        "bgDisabled":  { "$value": "{color.neutral.200}","$type": "color" },
        "text":        { "$value": "{color.neutral.0}",  "$type": "color" },
        "textDisabled":{ "$value": "{color.neutral.400}","$type": "color" }
      },

      "success": {
        "bg":     { "$value": "#f0fdf4", "$type": "color" },
        "border": { "$value": "#86efac", "$type": "color" },
        "text":   { "$value": "#166534", "$type": "color" },
        "icon":   { "$value": "#16a34a", "$type": "color" }
      },

      "warning": {
        "bg":     { "$value": "#fffbeb", "$type": "color" },
        "border": { "$value": "#fcd34d", "$type": "color" },
        "text":   { "$value": "#92400e", "$type": "color" },
        "icon":   { "$value": "#d97706", "$type": "color" }
      },

      "danger": {
        "bg":     { "$value": "#fef2f2", "$type": "color" },
        "border": { "$value": "#fca5a5", "$type": "color" },
        "text":   { "$value": "#991b1b", "$type": "color" },
        "icon":   { "$value": "#dc2626", "$type": "color" }
      },

      "info": {
        "bg":     { "$value": "{color.brand.50}",  "$type": "color" },
        "border": { "$value": "{color.brand.200}", "$type": "color" },
        "text":   { "$value": "{color.brand.900}", "$type": "color" },
        "icon":   { "$value": "{color.brand.600}", "$type": "color" }
      }
    }
  },

  "typography": {
    "$description": "1.25 modular type scale (minor third). Base 16 px. Stack: system-ui → fallbacks.",

    "fontFamily": {
      "sans": {
        "$value": "system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif",
        "$type": "fontFamily"
      },
      "mono": {
        "$value": "'JetBrains Mono', 'Fira Code', 'Cascadia Code', 'Courier New', Courier, monospace",
        "$type": "fontFamily"
      }
    },

    "fontSize": {
      "$description": "Scale: each step × 1.25 from base (16 px). Values rounded to nearest 0.5 px.",
      "2xs": { "$value": "0.64rem",  "$type": "dimension", "$description": "~10.24 px" },
      "xs":  { "$value": "0.8rem",   "$type": "dimension", "$description": "~12.8 px" },
      "sm":  { "$value": "0.875rem", "$type": "dimension", "$description": "14 px (practical step)" },
      "md":  { "$value": "1rem",     "$type": "dimension", "$description": "16 px base" },
      "lg":  { "$value": "1.25rem",  "$type": "dimension", "$description": "20 px" },
      "xl":  { "$value": "1.5625rem","$type": "dimension", "$description": "25 px" },
      "2xl": { "$value": "1.953rem", "$type": "dimension", "$description": "~31 px" },
      "3xl": { "$value": "2.441rem", "$type": "dimension", "$description": "~39 px" },
      "4xl": { "$value": "3.052rem", "$type": "dimension", "$description": "~49 px" }
    },

    "fontWeight": {
      "regular": { "$value": "400", "$type": "fontWeight" },
      "medium":  { "$value": "500", "$type": "fontWeight" },
      "semibold":{ "$value": "600", "$type": "fontWeight" },
      "bold":    { "$value": "700", "$type": "fontWeight" }
    },

    "lineHeight": {
      "tight":  { "$value": "1.25", "$type": "number" },
      "snug":   { "$value": "1.375","$type": "number" },
      "normal": { "$value": "1.5",  "$type": "number" },
      "relaxed":{ "$value": "1.625","$type": "number" }
    },

    "letterSpacing": {
      "tight":  { "$value": "-0.02em", "$type": "dimension" },
      "normal": { "$value": "0em",     "$type": "dimension" },
      "wide":   { "$value": "0.04em",  "$type": "dimension" },
      "widest": { "$value": "0.08em",  "$type": "dimension" }
    }
  },

  "spacing": {
    "$description": "8 px grid. Every value is a multiple of 4 px (half-grid) or 8 px (full grid).",
    "0":   { "$value": "0px",    "$type": "dimension" },
    "px":  { "$value": "1px",    "$type": "dimension" },
    "0.5": { "$value": "2px",    "$type": "dimension" },
    "1":   { "$value": "4px",    "$type": "dimension" },
    "1.5": { "$value": "6px",    "$type": "dimension" },
    "2":   { "$value": "8px",    "$type": "dimension" },
    "3":   { "$value": "12px",   "$type": "dimension" },
    "4":   { "$value": "16px",   "$type": "dimension" },
    "5":   { "$value": "20px",   "$type": "dimension" },
    "6":   { "$value": "24px",   "$type": "dimension" },
    "8":   { "$value": "32px",   "$type": "dimension" },
    "10":  { "$value": "40px",   "$type": "dimension" },
    "12":  { "$value": "48px",   "$type": "dimension" },
    "16":  { "$value": "64px",   "$type": "dimension" },
    "20":  { "$value": "80px",   "$type": "dimension" },
    "24":  { "$value": "96px",   "$type": "dimension" },
    "32":  { "$value": "128px",  "$type": "dimension" },
    "40":  { "$value": "160px",  "$type": "dimension" },
    "48":  { "$value": "192px",  "$type": "dimension" },
    "56":  { "$value": "224px",  "$type": "dimension" },
    "64":  { "$value": "256px",  "$type": "dimension" }
  },

  "borderRadius": {
    "$description": "From sharp to pill. Consistent with 8 px grid.",
    "none": { "$value": "0px",    "$type": "dimension" },
    "sm":   { "$value": "4px",    "$type": "dimension" },
    "md":   { "$value": "8px",    "$type": "dimension" },
    "lg":   { "$value": "12px",   "$type": "dimension" },
    "xl":   { "$value": "16px",   "$type": "dimension" },
    "2xl":  { "$value": "24px",   "$type": "dimension" },
    "full": { "$value": "9999px", "$type": "dimension", "$description": "Pill / avatar / badge" }
  },

  "shadow": {
    "$description": "Elevation ramp. Use shadow, not colour alone, to convey z-depth.",
    "none": { "$value": "none", "$type": "shadow" },
    "xs":   { "$value": "0 1px 2px 0 rgb(0 0 0 / 0.05)", "$type": "shadow" },
    "sm":   { "$value": "0 1px 3px 0 rgb(0 0 0 / 0.10), 0 1px 2px -1px rgb(0 0 0 / 0.10)", "$type": "shadow" },
    "md":   { "$value": "0 4px 6px -1px rgb(0 0 0 / 0.10), 0 2px 4px -2px rgb(0 0 0 / 0.10)", "$type": "shadow" },
    "lg":   { "$value": "0 10px 15px -3px rgb(0 0 0 / 0.10), 0 4px 6px -4px rgb(0 0 0 / 0.10)", "$type": "shadow" },
    "xl":   { "$value": "0 20px 25px -5px rgb(0 0 0 / 0.10), 0 8px 10px -6px rgb(0 0 0 / 0.10)", "$type": "shadow" },
    "2xl":  { "$value": "0 25px 50px -12px rgb(0 0 0 / 0.25)", "$type": "shadow" },
    "inner":{ "$value": "inset 0 2px 4px 0 rgb(0 0 0 / 0.05)", "$type": "shadow" },
    "focus":{ "$value": "0 0 0 3px rgb(99 102 241 / 0.40)", "$type": "shadow", "$description": "Brand focus ring, accessible blue-indigo" }
  },

  "transition": {
    "$description": "Motion presets. Prefer these over raw ms/easing values.",
    "fast":    { "$value": "100ms ease-out", "$type": "transition" },
    "default": { "$value": "150ms ease-out", "$type": "transition" },
    "medium":  { "$value": "250ms ease-out", "$type": "transition" },
    "slow":    { "$value": "350ms ease-in-out", "$type": "transition" }
  },

  "zIndex": {
    "$description": "Z-axis layers. Never use arbitrary integers.",
    "base":    { "$value": "0",    "$type": "number" },
    "raised":  { "$value": "1",    "$type": "number" },
    "dropdown":{ "$value": "100",  "$type": "number" },
    "sticky":  { "$value": "200",  "$type": "number" },
    "overlay": { "$value": "300",  "$type": "number" },
    "modal":   { "$value": "400",  "$type": "number" },
    "toast":   { "$value": "500",  "$type": "number" },
    "tooltip": { "$value": "600",  "$type": "number" }
  }
}
